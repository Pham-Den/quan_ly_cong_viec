generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projects       Project[]
  refreshTokens  RefreshToken[]
  timelineEvents TimelineEvent[]
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Project {
  id             String   @id @default(cuid())
  ownerId        String?
  defaultRepoId  String?
  code           String   @unique
  name           String
  description    String?
  nextTaskNumber Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  owner             User?            @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  defaultRepository Repository?      @relation("ProjectDefaultRepository", fields: [defaultRepoId], references: [id], onDelete: SetNull)
  repositories      Repository[]     @relation("ProjectRepositories")
  taskGroups        TaskGroup[]
  notes             Note[]
  tasks             Task[]
  workflowStatuses  WorkflowStatus[]
  timelineEvents    TimelineEvent[]
  apiEnvironments   ApiEnvironment[]
  apiRequests       ApiRequest[]
  apiFlows          ApiFlow[]
  apiRequestRuns    ApiRequestRun[]
  apiFlowRuns       ApiFlowRun[]

  @@index([ownerId])
  @@index([defaultRepoId])
}

model TaskGroup {
  id             String   @id @default(cuid())
  projectId      String
  code           String
  name           String
  description    String?
  enabled        Boolean  @default(true)
  nextTaskNumber Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([projectId, code])
  @@index([projectId])
}

model Repository {
  id                             String   @id @default(cuid())
  projectId                      String
  name                           String
  provider                       String   @default("GITLAB_SELF_HOSTED")
  gitlabUrl                      String?
  gitlabProjectId                String?
  gitlabProjectPath              String?
  gitlabAccessToken              String?
  defaultBranch                  String   @default("main")
  productionBranch               String   @default("main")
  releaseBranchPattern           String   @default("release/DDMMYYYY")
  trustSourceBranch              String   @default("main")
  developBranch                  String   @default("develop")
  featureNamePattern             String   @default("feature/{jiraCode}")
  hotfixNamePattern              String   @default("hotfix/{jiraCode}-{date}")
  featurePlannedTargets          String   @default("{develop},{activeRelease},{production}")
  hotfixPlannedTargets           String   @default("{activeRelease},{production}")
  allowCheckoutSourceOverride    Boolean  @default(false)
  allowDirectTaskBranchMainMerge Boolean  @default(false)
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt

  project            Project        @relation("ProjectRepositories", fields: [projectId], references: [id], onDelete: Cascade)
  defaultForProjects Project[]      @relation("ProjectDefaultRepository")
  branches           Branch[]
  releaseCycles      ReleaseCycle[]

  @@unique([projectId, name])
  @@index([projectId])
  @@index([provider])
}

model ReleaseCycle {
  id           String    @id @default(cuid())
  repositoryId String
  name         String
  status       String    @default("ACTIVE")
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  branches   Branch[]

  @@unique([repositoryId, name])
  @@index([repositoryId, status])
}

model WorkflowStatus {
  id                   String   @id @default(cuid())
  projectId            String?
  scope                String
  key                  String
  label                String
  color                String
  sortOrder            Int
  enabled              Boolean  @default(true)
  allowKanbanDrop      Boolean?
  dropBlockReason      String?
  requiresConfirmation Boolean?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, scope, key])
  @@index([projectId, scope])
  @@index([scope, sortOrder])
}

model Note {
  id        String   @id @default(cuid())
  projectId String?
  content   String
  source    String?
  status    String   @default("NEW")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project       Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  convertedTask Task?

  @@index([projectId, status])
  @@index([status])
}

model Task {
  id             String    @id @default(cuid())
  projectId      String
  taskGroupId    String?
  sourceNoteId   String?   @unique
  code           String    @unique
  title          String
  description    String?
  status         String    @default("PLANNED")
  workStatus     String    @default("TODO")
  priority       String    @default("MEDIUM")
  type           String    @default("FEATURE")
  targetDate     DateTime?
  releaseReadyAt DateTime?
  doneAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskGroup      TaskGroup?      @relation(fields: [taskGroupId], references: [id], onDelete: SetNull)
  sourceNote     Note?           @relation(fields: [sourceNoteId], references: [id], onDelete: SetNull)
  branchLinks    TaskBranch[]
  timelineEvents TimelineEvent[]
  apiRequests    ApiRequest[]
  apiFlows       ApiFlow[]
  apiRequestRuns ApiRequestRun[]
  apiFlowRuns    ApiFlowRun[]

  @@index([projectId, status])
  @@index([projectId, workStatus])
  @@index([projectId, taskGroupId])
  @@index([status])
  @@index([targetDate])
}

model Branch {
  id                       String    @id @default(cuid())
  repositoryId             String
  sourceBranchId           String?
  releaseCycleId           String?
  name                     String
  shortName                String?
  branchType               String    @default("FEATURE")
  status                   String    @default("CODING")
  checkoutSourceBranch     String?
  lineageId                String?
  intendedMergeTarget      String?
  actualMergedInto         String?
  baseBranch               String?
  mergeRequestUrl          String?
  releaseCycleDate         DateTime?
  generatedCheckoutCommand String?
  remoteCreated            Boolean   @default(false)
  mergedReleaseAt          DateTime?
  mergedMainAt             DateTime?
  sortOrder                Int       @default(0)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  repository         Repository      @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  releaseCycle       ReleaseCycle?   @relation(fields: [releaseCycleId], references: [id], onDelete: SetNull)
  sourceBranch       Branch?         @relation("BranchSource", fields: [sourceBranchId], references: [id], onDelete: SetNull)
  derivedBranches    Branch[]        @relation("BranchSource")
  aliases            BranchAlias[]
  taskLinks          TaskBranch[]    @relation("BranchTaskLinks")
  inheritedTaskLinks TaskBranch[]    @relation("TaskBranchInheritedFrom")
  timelineEvents     TimelineEvent[]

  @@unique([repositoryId, name])
  @@index([repositoryId, branchType])
  @@index([status])
  @@index([status, sortOrder])
  @@index([lineageId])
  @@index([sourceBranchId])
  @@index([releaseCycleId])
}

model BranchAlias {
  id        String   @id @default(cuid())
  branchId  String
  alias     String
  createdAt DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, alias])
  @@index([alias])
}

model TaskBranch {
  id                    String   @id @default(cuid())
  taskId                String
  branchId              String
  inheritedFromBranchId String?
  role                  String   @default("PRIMARY")
  lineageId             String?
  active                Boolean  @default(true)
  completionRequired    Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  task                Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  branch              Branch  @relation("BranchTaskLinks", fields: [branchId], references: [id], onDelete: Cascade)
  inheritedFromBranch Branch? @relation("TaskBranchInheritedFrom", fields: [inheritedFromBranchId], references: [id], onDelete: SetNull)

  @@unique([taskId, branchId, role])
  @@index([taskId, branchId])
  @@index([branchId])
  @@index([lineageId])
  @@index([active, completionRequired])
}

model ApiEnvironment {
  id              String   @id @default(cuid())
  projectId       String
  name            String
  environmentType String   @default("CUSTOM")
  baseUrl         String?
  description     String?
  enabled         Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project     Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  variables   ApiEnvironmentVariable[]
  requestRuns ApiRequestRun[]
  flowRuns    ApiFlowRun[]

  @@unique([projectId, name])
  @@index([projectId, environmentType])
  @@index([projectId, sortOrder])
}

model ApiEnvironmentVariable {
  id            String   @id @default(cuid())
  environmentId String
  key           String
  secret        Boolean  @default(false)
  description   String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  environment ApiEnvironment                  @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  variants    ApiEnvironmentVariableVariant[]

  @@unique([environmentId, key])
  @@index([environmentId, sortOrder])
}

model ApiEnvironmentVariableVariant {
  id         String   @id @default(cuid())
  variableId String
  name       String
  value      String
  enabled    Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  variable ApiEnvironmentVariable @relation(fields: [variableId], references: [id], onDelete: Cascade)

  @@unique([variableId, name])
  @@index([variableId, sortOrder])
}

model ApiRequest {
  id                String   @id @default(cuid())
  projectId         String
  taskId            String?
  collectionName    String   @default("Mac dinh")
  name              String
  description       String?
  method            String   @default("GET")
  url               String
  queryJson         String   @default("[]")
  headersJson       String   @default("[]")
  bodyType          String   @default("NONE")
  bodyText          String?
  authJson          String   @default("{}")
  timeoutMs         Int      @default(30000)
  storeResponseBody Boolean  @default(false)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task        Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  flowSteps   ApiFlowStep[]
  requestRuns ApiRequestRun[]

  @@index([projectId, collectionName])
  @@index([projectId, taskId])
  @@index([method])
  @@index([sortOrder])
}

model ApiFlow {
  id                String   @id @default(cuid())
  projectId         String
  taskId            String?
  collectionName    String   @default("Mac dinh")
  name              String
  description       String?
  enabled           Boolean  @default(true)
  storeResponseBody Boolean  @default(false)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task     Task?         @relation(fields: [taskId], references: [id], onDelete: SetNull)
  steps    ApiFlowStep[]
  flowRuns ApiFlowRun[]

  @@index([projectId, collectionName])
  @@index([projectId, taskId])
  @@index([enabled])
  @@index([sortOrder])
}

model ApiFlowStep {
  id                 String   @id @default(cuid())
  flowId             String
  requestId          String?
  name               String
  sortOrder          Int      @default(0)
  overrideJson       String   @default("{}")
  captureRulesJson   String   @default("[]")
  assertionRulesJson String   @default("[]")
  continueOnFailure  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  flow        ApiFlow         @relation(fields: [flowId], references: [id], onDelete: Cascade)
  request     ApiRequest?     @relation(fields: [requestId], references: [id], onDelete: SetNull)
  requestRuns ApiRequestRun[]

  @@index([flowId, sortOrder])
  @@index([requestId])
}

model ApiFlowRun {
  id                    String    @id @default(cuid())
  projectId             String
  taskId                String?
  environmentId         String?
  flowId                String?
  status                String    @default("PENDING")
  durationMs            Int?
  assertionSummaryJson  String    @default("{}")
  capturedVariablesJson String    @default("{}")
  errorMessage          String?
  startedAt             DateTime  @default(now())
  finishedAt            DateTime?
  createdAt             DateTime  @default(now())

  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task        Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  environment ApiEnvironment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  flow        ApiFlow?        @relation(fields: [flowId], references: [id], onDelete: SetNull)
  stepRuns    ApiRequestRun[]

  @@index([projectId, createdAt])
  @@index([taskId])
  @@index([environmentId])
  @@index([flowId])
  @@index([status])
}

model ApiRequestRun {
  id                    String    @id @default(cuid())
  projectId             String
  taskId                String?
  environmentId         String?
  requestId             String?
  flowRunId             String?
  flowStepId            String?
  status                String    @default("PENDING")
  httpStatus            Int?
  durationMs            Int?
  assertionSummaryJson  String    @default("{}")
  capturedVariablesJson String    @default("{}")
  errorMessage          String?
  responseBodySaved     Boolean   @default(false)
  startedAt             DateTime  @default(now())
  finishedAt            DateTime?
  createdAt             DateTime  @default(now())

  project       Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task          Task?             @relation(fields: [taskId], references: [id], onDelete: SetNull)
  environment   ApiEnvironment?   @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  request       ApiRequest?       @relation(fields: [requestId], references: [id], onDelete: SetNull)
  flowRun       ApiFlowRun?       @relation(fields: [flowRunId], references: [id], onDelete: Cascade)
  flowStep      ApiFlowStep?      @relation(fields: [flowStepId], references: [id], onDelete: SetNull)
  savedResponse ApiSavedResponse?

  @@index([projectId, createdAt])
  @@index([taskId])
  @@index([environmentId])
  @@index([requestId])
  @@index([flowRunId])
  @@index([flowStepId])
  @@index([status])
}

model ApiSavedResponse {
  id           String   @id @default(cuid())
  requestRunId String   @unique
  statusCode   Int?
  headersJson  String   @default("{}")
  bodyText     String?
  contentType  String?
  originalSize Int?
  truncated    Boolean  @default(false)
  createdAt    DateTime @default(now())

  requestRun ApiRequestRun @relation(fields: [requestRunId], references: [id], onDelete: Cascade)
}

model SystemEnvironment {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hosts        SystemHost[]
  nodes        SystemTopologyNode[]
  dependencies SystemDependency[]
  nodeBindings SystemNodeEnvironmentBinding[]
  dependencyBindings SystemDependencyEnvironmentBinding[]

  @@index([sortOrder])
}

model SystemHost {
  id            String   @id @default(cuid())
  environmentId String
  name          String
  ip            String
  description   String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  environment SystemEnvironment    @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  nodes       SystemTopologyNode[]
  nodeBindings SystemNodeEnvironmentBinding[]

  @@unique([environmentId, name])
  @@index([environmentId, sortOrder])
  @@index([ip])
}

model SystemTopologyBlueprintNode {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  kind        String
  type        String
  description String?
  notes       String?
  positionX   Int      @default(0)
  positionY   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bindings      SystemNodeEnvironmentBinding[]
  outgoingEdges SystemTopologyBlueprintDependency[] @relation("SystemBlueprintDependencySource")
  incomingEdges SystemTopologyBlueprintDependency[] @relation("SystemBlueprintDependencyTarget")

  @@index([kind])
  @@index([type])
}

model SystemNodeEnvironmentBinding {
  id            String   @id @default(cuid())
  environmentId String
  nodeId        String
  hostId        String?
  displayName   String?
  status        String   @default("unknown")
  tagsJson      String   @default("[]")
  containerName String?
  image         String?
  portsJson     String   @default("[]")
  network       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  environment SystemEnvironment             @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  node        SystemTopologyBlueprintNode   @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  host        SystemHost?                   @relation(fields: [hostId], references: [id], onDelete: SetNull)
  configGroups SystemNodeBindingConfigGroup[]

  @@unique([environmentId, nodeId])
  @@index([environmentId])
  @@index([nodeId])
  @@index([hostId])
  @@index([status])
}

model SystemNodeBindingConfigGroup {
  id        String   @id @default(cuid())
  bindingId String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  binding SystemNodeEnvironmentBinding @relation(fields: [bindingId], references: [id], onDelete: Cascade)
  items   SystemNodeBindingConfigItem[]

  @@unique([bindingId, name])
  @@index([bindingId, sortOrder])
}

model SystemNodeBindingConfigItem {
  id        String   @id @default(cuid())
  groupId   String
  key       String
  value     String
  secret    Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group SystemNodeBindingConfigGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, key])
  @@index([groupId, sortOrder])
  @@index([key])
}

model SystemTopologyBlueprintDependency {
  id             String   @id @default(cuid())
  code           String   @unique
  sourceNodeId   String
  targetNodeId   String
  label          String
  connectionType String
  direction      String
  port           String?
  description    String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sourceNode SystemTopologyBlueprintNode     @relation("SystemBlueprintDependencySource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode SystemTopologyBlueprintNode     @relation("SystemBlueprintDependencyTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)
  bindings   SystemDependencyEnvironmentBinding[]

  @@index([sourceNodeId])
  @@index([targetNodeId])
  @@index([direction])
  @@index([sortOrder])
}

model SystemDependencyEnvironmentBinding {
  id             String   @id @default(cuid())
  environmentId  String
  dependencyId   String
  label          String?
  connectionType String?
  direction      String?
  port           String?
  description    String?
  sortOrder      Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  environment SystemEnvironment                @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  dependency  SystemTopologyBlueprintDependency @relation(fields: [dependencyId], references: [id], onDelete: Cascade)
  configItems SystemDependencyBindingConfig[]

  @@unique([environmentId, dependencyId])
  @@index([environmentId])
  @@index([dependencyId])
}

model SystemDependencyBindingConfig {
  id        String   @id @default(cuid())
  bindingId String
  key       String
  value     String
  secret    Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  binding SystemDependencyEnvironmentBinding @relation(fields: [bindingId], references: [id], onDelete: Cascade)

  @@unique([bindingId, key])
  @@index([bindingId, sortOrder])
  @@index([key])
}

model SystemTopologyNode {
  id            String   @id @default(cuid())
  environmentId String
  hostId        String?
  code          String
  name          String
  kind          String
  type          String
  status        String   @default("unknown")
  description   String?
  tagsJson      String   @default("[]")
  containerName String?
  image         String?
  portsJson     String   @default("[]")
  network       String?
  notes         String?
  positionX     Int      @default(0)
  positionY     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  environment      SystemEnvironment      @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  host             SystemHost?            @relation(fields: [hostId], references: [id], onDelete: SetNull)
  configGroups     SystemNodeConfigGroup[]
  outgoingEdges    SystemDependency[]     @relation("SystemDependencySource")
  incomingEdges    SystemDependency[]     @relation("SystemDependencyTarget")

  @@unique([environmentId, code])
  @@index([environmentId, kind])
  @@index([environmentId, type])
  @@index([environmentId, status])
  @@index([hostId])
}

model SystemNodeConfigGroup {
  id        String   @id @default(cuid())
  nodeId    String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  node  SystemTopologyNode  @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  items SystemNodeConfigItem[]

  @@unique([nodeId, name])
  @@index([nodeId, sortOrder])
}

model SystemNodeConfigItem {
  id        String   @id @default(cuid())
  groupId   String
  key       String
  value     String
  secret    Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group SystemNodeConfigGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, key])
  @@index([groupId, sortOrder])
  @@index([key])
}

model SystemDependency {
  id             String   @id @default(cuid())
  environmentId  String
  code           String
  sourceNodeId   String
  targetNodeId   String
  label          String
  connectionType String
  direction      String
  port           String?
  description    String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  environment SystemEnvironment        @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  sourceNode  SystemTopologyNode       @relation("SystemDependencySource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode  SystemTopologyNode       @relation("SystemDependencyTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)
  configItems SystemDependencyConfig[]

  @@unique([environmentId, code])
  @@index([environmentId, sortOrder])
  @@index([sourceNodeId])
  @@index([targetNodeId])
  @@index([direction])
}

model SystemDependencyConfig {
  id           String   @id @default(cuid())
  dependencyId String
  key          String
  value        String
  secret       Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  dependency SystemDependency @relation(fields: [dependencyId], references: [id], onDelete: Cascade)

  @@unique([dependencyId, key])
  @@index([dependencyId, sortOrder])
  @@index([key])
}

model TimelineEvent {
  id           String   @id @default(cuid())
  projectId    String
  taskId       String?
  branchId     String?
  createdById  String?
  eventType    String
  title        String
  description  String?
  metadataJson String   @default("{}")
  createdAt    DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task      Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)
  branch    Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdBy User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([taskId])
  @@index([branchId])
  @@index([eventType])
  @@index([createdById])
}
