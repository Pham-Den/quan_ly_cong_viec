{
  "name": "@sdlc-framework/docs-viewer",
  "version": "0.1.0",
  "description": "Zero-config doc viewer for architecture docs (md / drawio / mermaid / images / pdf / csv).",
  "type": "module",
  "bin": {
    "docs-view": "./bin/docs-view.js"
  },
  "files": [
    "launch.cmd",
    "launch.ps1",
    "launch.sh",
    "bin",
    "scripts",
    "src",
    "theme",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "debug": "^4.4.0",
    "diff": "^9.0.0",
    "marked": "^18.0.5",
    "mermaid": "^11.4.0",
    "papaparse": "^5.4.1",
    "vitepress": "^1.5.0",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vue": "^3.5.0"
  },
  "scripts": {
    "dev": "node ./bin/docs-view.js",
    "launch": "node ./scripts/launch.mjs",
    "dev:watch": "node --watch-path=src --watch-path=bin ./bin/docs-view.js dev",
    "smoke": "node ./scripts/smoke-test.mjs",
    "test:prism": "node ./scripts/prism-test.mjs",
    "test": "node ./scripts/smoke-test.mjs && node ./scripts/prism-test.mjs",
    "release": "node ./scripts/release.mjs"
  }
}
